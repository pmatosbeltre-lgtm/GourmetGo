@using Microsoft.AspNetCore.Components.Authorization
@using GourmetGo.Web.Handlers
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

<header class="d-flex justify-content-between align-items-center p-3 shadow-sm" style="background-color: var(--blanco); border-bottom: 2px solid var(--crema);">

    <div class="d-flex align-items-center">
        <AuthorizeView Roles="Cliente">
            <Authorized>
                <div class="input-group" style="width: 300px;">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control bg-light border-0 shadow-none" placeholder="Buscar restaurantes..." />
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="d-flex align-items-center gap-3">
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-light position-relative" style="border-radius: 50%; width: 45px; height: 45px;">
                    <i class="bi bi-bell-fill text-muted"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        2
                    </span>
                </button>

                <div class="dropdown">
                    <button class="btn btn-outline-dark dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 20px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="background-color: var(--noche); width: 30px; height: 30px;">
                            @ObtenerIniciales(context.User.Identity?.Name)
                        </div>
                        <span class="fw-bold">@context.User.Identity?.Name</span>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" style="border-radius: 15px;">
                        <AuthorizeView Roles="Cliente" Context="clienteCtx">
                            <li><a class="dropdown-item py-2" href="/mis-reservas"><i class="bi bi-calendar-check me-2 text-muted"></i> Mis Reservas</a></li>
                            <li><a class="dropdown-item py-2" href="/mis-favoritos"><i class="bi bi-heart me-2 text-muted"></i> Favoritos</a></li>
                        </AuthorizeView>

                        <AuthorizeView Roles="Propietario" Context="propCtx">
                            <li><a class="dropdown-item py-2" href="/restaurantes/gestion"><i class="bi bi-shop me-2 text-muted"></i> Mi Restaurante</a></li>
                            <li><a class="dropdown-item py-2" href="/ordenes"><i class="bi bi-receipt me-2 text-muted"></i> Órdenes Activas</a></li>
                        </AuthorizeView>

                        <li><hr class="dropdown-divider"></li>
                        <li><button class="dropdown-item text-danger py-2 fw-bold" @onclick="CerrarSesion"><i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión</button></li>
                    </ul>
                </div>
            </Authorized>

            <NotAuthorized>
                <a href="/login" class="btn btn-outline-dark fw-bold" style="border-radius: 12px;">Entrar</a>
                <a href="/registro" class="btn fw-bold text-white" style="background-color: var(--otono); border-radius: 12px;">Registrarse</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</header>

@code {
    private string ObtenerIniciales(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "U";
        return nombre.Substring(0, 1).ToUpper();
    }

    private void CerrarSesion()
    {
       
        var customProvider = (CustomAuthStateProvider)AuthProvider;
        customProvider.MarkUserAsLoggedOut();

        Navigation.NavigateTo("/login", true);
    }
}