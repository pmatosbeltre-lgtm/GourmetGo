@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization
@using GourmetGo.Web.Handlers
@inject AuthenticationStateProvider AuthProvider
@rendermode InteractiveServer

<header class="d-flex justify-content-between align-items-center p-3 shadow-lg" style="background-color: var(--color-noche); border-radius: 0 0 25px 25px; margin-bottom: 30px;">

    <div class="d-flex align-items-center gap-4 px-3">
        @* LOGO *@
        <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
            <div class="rounded-3 d-flex align-items-center justify-content-center text-white p-2" style="background-color: var(--color-otoño);">
                <i class="bi bi-shop"></i>
            </div>
            <span class="fw-bold fs-4 text-white">Gourmet<span style="color: var(--color-otoño);">Go</span></span>
        </a>

        @* BOTONES DE GESTIÓN (Solo si está logueado) *@
        <AuthorizeView>
            <Authorized>
                <div class="d-flex gap-2 align-items-center ms-2">
                    <a href="/restaurantes/crear" class="btn btn-crear-especial">
                        <i class="bi bi-plus-circle-fill me-2"></i>
                        <span>Crear Restaurante</span>
                    </a>

                    <a href="/menu/1" class="btn btn-menu-especial">
                        <i class="bi bi-egg-fried me-2"></i>
                        <span>Gestionar Platos</span>
                    </a>
                </div>
            </Authorized>
        </AuthorizeView>

        @* SECCIÓN BUSCADOR (Solo para Clientes) *@
        <AuthorizeView Roles="Cliente">
            <Authorized>
                <div class="d-flex gap-4 ms-4 align-items-center">
                    <div class="input-group input-group-sm shadow-sm" style="width: 250px; border-radius: 12px; overflow: hidden;">
                        <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control bg-white border-0 shadow-none" placeholder="Buscar..." />
                    </div>
                    <a href="/mis-reservas" class="text-decoration-none fw-bold text-white opacity-75 custom-hover small">
                        <i class="bi bi-calendar-check me-1"></i> Reservas
                    </a>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    @* SECCIÓN DERECHA: USUARIO / LOGIN *@
    <div class="d-flex align-items-center gap-3 px-3">
        <AuthorizeView>
            <Authorized>
                <div class="dropdown">
                    <button class="btn dropdown-toggle d-flex align-items-center gap-2 px-3 py-2 shadow-sm text-white" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 20px; background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="background-color: var(--color-otoño); width: 30px; height: 30px;">
                            @ObtenerIniciales(context.User.Identity?.Name)
                        </div>
                        <span class="fw-bold">@context.User.Identity?.Name</span>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2" style="border-radius: 15px;">
                        <li>
                            <button class="dropdown-item text-danger py-2 fw-bold" @onclick="CerrarSesion">
                                <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                            </button>
                        </li>
                    </ul>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="d-flex gap-2">
                    <a href="/login" class="btn btn-outline-light fw-bold" style="border-radius: 12px; padding: 10px 20px;">Entrar</a>
                    <a href="/registro" class="btn fw-bold text-white shadow-sm" style="background-color: var(--color-otoño); border-radius: 12px; padding: 10px 20px;">Registrarse</a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</header>

<style>
    .custom-hover:hover {
        opacity: 1 !important;
        color: var(--color-otoño) !important;
        transition: 0.3s;
    }

    .btn-crear-especial {
        color: white !important;
        background-color: #e67e22 !important;
        border-radius: 12px;
        padding: 6px 18px !important;
        font-weight: bold;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        text-decoration: none;
        display: flex;
        align-items: center;
        border: none;
    }

        .btn-crear-especial:hover {
            background-color: #d35400 !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

    .btn-menu-especial {
        color: white !important;
        background-color: rgba(255, 255, 255, 0.08) !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        border-radius: 12px;
        padding: 6px 18px !important;
        font-weight: bold;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        text-decoration: none;
        display: flex;
        align-items: center;
    }

        .btn-menu-especial:hover {
            background-color: rgba(255, 255, 255, 0.15) !important;
            border-color: var(--color-otoño) !important;
            transform: translateY(-2px);
        }
</style>

@code {
    private string ObtenerIniciales(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "U";
        return nombre.Substring(0, 1).ToUpper();
    }

    private void CerrarSesion()
    {
        var customProvider = (CustomAuthStateProvider)AuthProvider;
        customProvider.MarkUserAsLoggedOut();
        Navigation.NavigateTo("/login", true);
    }
}